# Copia este archivo a .env.local y rellena los valores.
# En Vercel: Project → Settings → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_de_supabase

# Service Role Key (solo servidor, nunca exponer en el cliente)
# Supabase Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis para rate limiting (login, API)
# https://console.upstash.com → Create Database
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXX...

# URL base de formularios de inscripción (por defecto: https://inscripcion.snrg.lat)
# NEXT_PUBLIC_INSCRIPCION_BASE_URL=https://inscripcion.snrg.lat

# Brevo API Key (v3 REST, empieza con xkeysib-...)
# Obtener en: Cuenta Brevo > Configuración > SMTP & API
# Es la MISMA clave para email Y SMS (no hay claves separadas para SMTP vs API)
# Se usa para: formularios (listas)
# BREVO_API_KEY=xkeysib-tu_clave_aqui

# Código de país para normalizar teléfonos de miembros (ej. 57 Colombia, 52 México)
# DEFAULT_SMS_COUNTRY_CODE=57

# Credenciales para el panel (REQUERIDO en producción - nunca dejar valores por defecto)
# LOGIN_EMAIL=tu_email@dominio.com
# LOGIN_PASSWORD=tu_contraseña_segura

# Panel de miembros (miembros.snrg.lat) - sesión por teléfono
# Generar con: openssl rand -base64 32  (mínimo 32 caracteres, NO es un teléfono)
# MEMBER_SESSION_SECRET=

# URL del subdominio de miembros (para redirect tras login desde snrg.lat)
# NEXT_PUBLIC_MIEMBROS_URL=https://miembros.snrg.lat

# ElevenLabs Conversational AI - llamadas salientes (/ia)
# Copia estas líneas a .env.local y rellena (NUNCA subas .env.local ni claves reales a Git).
# Dashboard: https://elevenlabs.io → Developers → API keys | Agents → tu agente
# ELEVENLABS_API_KEY=tu_xi_api_key
# ELEVENLABS_AGENT_ID=agent_xxxxxxxx
# ELEVENLABS_AGENT_PHONE_NUMBER_ID=phnum_xxxxxxxx
# Secreto del webhook (ElevenLabs lo muestra al crear el webhook) — obligatorio en prod
# ELEVENLABS_WEBHOOK_SECRET=whsec_...
# Webhook post-llamada: https://www.snrg.lat/api/webhooks/elevenlabs
# Diagnóstico payload en Vercel Logs (quitar tras depurar; puede loguear PII)
# ELEVENLABS_WEBHOOK_DEBUG=1

# Voyage AI — embeddings ia_call_profiles (scripts/backfill-embeddings.mjs)
# VOYAGE_API_KEY=pa-...
